{
  "schemaVersion": 1,
  "id": "coffee",
  "version": "${version}",
  "name": "Coffee V2",
  "description": "A free mixin-based injection hacked-client for Minecraft using the Fabric modding toolchain.",
  "authors": [
    "MaxEdgar"
  ],
  "contributors": $contributors,
  "contact": {
    "homepage": "https://github.com/MaxEdgar/CoffeeV2",
    "sources": "https://github.com/MaxEdgar/CoffeeV2/",
    "issues": "https://github.com/MaxEdgar/CoffeeV2/issues"
  },
  "license": "MIT",
  "icon": "resources/coffee/icon_64x64.png",
  "environment": "client",
  "entrypoints": {
    "main": []
  },
  "custom": {
    "modmenu": {
      "links": {
        "coffee.generic.forum": "https://github.com/MaxEdgar/CoffeeV2/discussions"
      }
    }
  },
  "mixins": [
    "coffee.mixins.json"
  ],
  "depends": {
    "minecraft": ["${minecraft_version}"],
    "fabricloader": ">=${min_loader_version}",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}"
  },
  "suggests": {
    "fabric": ">=${fabric_version}",
    "viafabricplus": ">=${viafabricplus_version}"
  },
  "breaks": {
    "viafabricplus": "<${viafabricplus_version}"
  },
  "accessWidener": "coffee.accesswidener"
}
